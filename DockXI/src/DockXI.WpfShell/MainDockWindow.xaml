<Window x:Class="DockXI.WpfShell.MainDockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
        xmlns:local="clr-namespace:DockXI.WpfShell"
        mc:Ignorable="d"
        x:Name="DockWindow"
        Title="DockXI"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="0"
        MinHeight="0"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Loaded="OnLoaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        <SineEase x:Key="EaseOut" EasingMode="EaseOut" />
        <SineEase x:Key="EaseIn"  EasingMode="EaseIn" />

        <!-- Tooltip overlay: plain white label, no background box, drop shadow.
             Placement=Top so the label hovers above the lifted tile. -->
        <Style x:Key="TooltipOverlayStyle" TargetType="ToolTip">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HasDropShadow"   Value="False" />
            <Setter Property="Placement"       Value="Top" />
            <Setter Property="VerticalOffset"  Value="-2" />
            <Setter Property="Foreground"      Value="White" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   Padding="0">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="0"
                                                  Color="Black" Opacity="0.85" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- ===== Win11-style dark ContextMenu ============================ -->
        <SolidColorBrush x:Key="MenuBg"        Color="#2C2C2C" />
        <SolidColorBrush x:Key="MenuBorder"    Color="#3F3F3F" />
        <SolidColorBrush x:Key="MenuFg"        Color="#F2F2F2" />
        <SolidColorBrush x:Key="MenuHover"     Color="#3E3E3E" />
        <SolidColorBrush x:Key="MenuSeparator" Color="#3F3F3F" />

        <Style x:Key="DockContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background"          Value="{StaticResource MenuBg}" />
            <Setter Property="BorderBrush"         Value="{StaticResource MenuBorder}" />
            <Setter Property="BorderThickness"     Value="1" />
            <Setter Property="Foreground"          Value="{StaticResource MenuFg}" />
            <Setter Property="FontFamily"          Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="FontSize"            Value="13" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding"   Value="True" />
            <Setter Property="HasDropShadow"       Value="True" />
            <Setter Property="Padding"             Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DockMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background"          Value="Transparent" />
            <Setter Property="Foreground"          Value="{StaticResource MenuFg}" />
            <Setter Property="Padding"             Value="12,6" />
            <Setter Property="Margin"              Value="0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Path x:Name="Check"
                                      Grid.Column="0"
                                      Data="M2,7 L6,11 L13,3"
                                      Stroke="{StaticResource MenuFg}"
                                      StrokeThickness="1.6"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center" />
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"
                                                  Margin="4,0,8,0" />
                                <Path x:Name="Chevron"
                                      Grid.Column="2"
                                      Data="M0,0 L4,4 L0,8"
                                      Stroke="{StaticResource MenuFg}"
                                      StrokeThickness="1.2"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0" />
                                <Popup x:Name="PART_Popup"
                                       Placement="Right"
                                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Fade">
                                    <Border CornerRadius="8"
                                            Background="{StaticResource MenuBg}"
                                            BorderBrush="{StaticResource MenuBorder}"
                                            BorderThickness="1"
                                            Padding="4"
                                            SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource MenuHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Chevron" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#808080" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DockSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="4,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{StaticResource MenuSeparator}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Tile button (hover lift) ================================ -->
        <Style x:Key="TileButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="2" />
            <Setter Property="Margin"          Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
<EventTrigger RoutedEvent="Button.Click">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                To="0" Duration="0:0:0.14"
                                FillBehavior="Stop"
                                EasingFunction="{StaticResource EaseOut}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                    To="-5" Duration="0:0:0.24"
                                    EasingFunction="{StaticResource EaseOut}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                    To="0" Duration="0:0:0.24"
                                    EasingFunction="{StaticResource EaseIn}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- BorderThickness=0 + Snap/UseLayoutRounding => no rounded-corner hairline.
         AllowDrop=True + DragEnter/Drop on Border so external file-drop works
         even when the dock is empty (ItemsControl has no children → no hit area). -->
    <Border x:Name="DockPlate"
            CornerRadius="10"
            Background="#E8202020"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1"
            Padding="{Binding ElementName=DockWindow, Path=PlatePadding}"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True"
            AllowDrop="True"
            DragEnter="DockPlate_DragEnter"
            DragOver="DockPlate_DragOver"
            DragLeave="DockPlate_DragLeave"
            Drop="DockPlate_Drop">
        <Border.ContextMenu>
            <ContextMenu Opened="DockMenu_Opened"
                         Style="{StaticResource DockContextMenuStyle}"
                         Foreground="{StaticResource MenuFg}">
                <MenuItem Header="Add file..."   Click="PinFile_Click"   Style="{StaticResource DockMenuItemStyle}" />
                <MenuItem Header="Add folder..." Click="PinFolder_Click" Style="{StaticResource DockMenuItemStyle}" />
                <Separator Style="{StaticResource DockSeparatorStyle}" />
                <MenuItem Header="Position" Style="{StaticResource DockMenuItemStyle}">
                    <MenuItem Header="Bottom" IsCheckable="True" Click="Position_Click" Tag="Bottom" Style="{StaticResource DockMenuItemStyle}" />
                    <MenuItem Header="Top"    IsCheckable="True" Click="Position_Click" Tag="Top"    Style="{StaticResource DockMenuItemStyle}" />
                    <MenuItem Header="Left"   IsCheckable="True" Click="Position_Click" Tag="Left"   Style="{StaticResource DockMenuItemStyle}" />
                    <MenuItem Header="Right"  IsCheckable="True" Click="Position_Click" Tag="Right"  Style="{StaticResource DockMenuItemStyle}" />
                </MenuItem>
                <MenuItem Header="Auto-hide" IsCheckable="True" Tag="AutoHide" Click="AutoHide_Click" Style="{StaticResource DockMenuItemStyle}" />
                <Separator Style="{StaticResource DockSeparatorStyle}" />
                <MenuItem Header="About DockXI" Click="About_Click" Style="{StaticResource DockMenuItemStyle}" />
                <MenuItem Header="Quit DockXI"  Click="Quit_Click"  Style="{StaticResource DockMenuItemStyle}" />
            </ContextMenu>
        </Border.ContextMenu>

        <Grid MinWidth="{Binding ElementName=DockWindow, Path=DockMinWidth}"
              MinHeight="{Binding ElementName=DockWindow, Path=DockMinHeight}">
            <ItemsControl x:Name="TilesHost"
                          ItemsSource="{Binding ElementName=DockWindow, Path=PinnedItems}"
                          Background="Transparent"
                          dd:DragDrop.IsDragSource="True"
                          dd:DragDrop.IsDropTarget="True"
                          dd:DragDrop.DragHandler="{Binding ElementName=DockWindow, Path=DragHandler}"
                          dd:DragDrop.DropHandler="{Binding ElementName=DockWindow, Path=DropHandler}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="{Binding ElementName=DockWindow, Path=ItemsOrientation}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid x:Name="TileSlot">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="TileTranslate" X="0" />
                            </Grid.RenderTransform>
                            <StackPanel Orientation="{Binding ElementName=DockWindow, Path=TileWrapOrientation}"
                                        FlowDirection="{Binding ElementName=DockWindow, Path=TileFlowDirection}">
                                <Grid>
                                    <Button Style="{StaticResource TileButtonStyle}"
                                            Click="Tile_Click"
                                            ToolTipService.InitialShowDelay="100"
                                            ToolTipOpening="Tile_ToolTipOpening">
                                        <Button.ToolTip>
                                            <ToolTip Content="{Binding DisplayName}"
                                                     Style="{StaticResource TooltipOverlayStyle}" />
                                        </Button.ToolTip>
                                        <Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource DockContextMenuStyle}"
                                                         Foreground="{StaticResource MenuFg}"
                                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="Delete"
                                                          Click="DeleteTile_Click"
                                                          Style="{StaticResource DockMenuItemStyle}" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.RenderTransform>
                                            <TranslateTransform Y="0" />
                                        </Button.RenderTransform>
                                        <Image Source="{Binding IconSource}"
                                               Width="40" Height="40"
                                               Opacity="{Binding IsBroken, Converter={StaticResource BoolToOpacityConverter}}"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Button>
                                    <!-- Broken-target badge: red circle with ! at top-right -->
                                    <Border Background="#C42B1C"
                                            CornerRadius="9"
                                            Width="14" Height="14"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-2,-2,0"
                                            BorderBrush="#202020" BorderThickness="2"
                                            Visibility="{Binding IsBroken, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="!" Foreground="White"
                                                   FontSize="9" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="0,-1,0,0" />
                                    </Border>
                                </Grid>
                                <Ellipse Width="5" Height="5"
                                         Fill="#0078D4"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Margin="1"
                                         Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Rectangle x:Name="InsertBar"
                       Width="1"
                       Fill="#E0FFFFFF"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Stretch"
                       Visibility="Collapsed"
                       IsHitTestVisible="False">
                <Rectangle.RenderTransform>
                    <TranslateTransform x:Name="InsertBarT" X="0" />
                </Rectangle.RenderTransform>
            </Rectangle>
        </Grid>
    </Border>
</Window>
